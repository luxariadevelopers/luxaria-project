{
  "name": "@luxaria/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Luxaria Developers ERP web portal",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:live": "E2E_LIVE_API=true playwright test"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@luxaria/shared-types": "workspace:*",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-data-grid": "^9.9.0",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "notistack": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@luxaria/eslint-config": "workspace:*",
    "@luxaria/tsconfig": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "typescript": "6.0.3",
    "vite": "^6.2.2"
  }
}
