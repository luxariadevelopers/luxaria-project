{
  "name": "@luxaria/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Luxaria Developers ERP NestJS backend",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js",
    "test:unit": "jest --passWithNoTests --config jest.config.js",
    "test:integration": "jest --runInBand --passWithNoTests --config jest.integration.config.js",
    "test:e2e": "jest --runInBand --passWithNoTests --config jest.e2e.config.js",
    "test:api": "pnpm run test:e2e",
    "test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "test:security": "jest --runInBand --config jest.config.js src/common/security src/modules/auth/auth.service.spec.ts src/config/env.validation.spec.ts src/modules/sessions/session.service.spec.ts src/modules/project-access"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@luxaria/shared-types": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.12",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.80.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "expo-server-sdk": "^6.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "mongoose": "^8.12.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@luxaria/eslint-config": "workspace:*",
    "@luxaria/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.12",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.1",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3"
  }
}
