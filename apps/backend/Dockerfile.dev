# Development image — NestJS with hot reload (bind-mount source in compose).
FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    python3 \
    make \
    g++ \
  && rm -rf /var/lib/apt/lists/* \
  && corepack enable \
  && corepack prepare pnpm@9.15.9 --activate

WORKDIR /app

ENV NODE_ENV=development \
    PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH \
    CHOKIDAR_USEPOLLING=true \
    WATCHPACK_POLLING=true

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/backend/package.json apps/backend/
COPY apps/web/package.json apps/web/
COPY packages/shared-types/package.json packages/shared-types/
COPY packages/shared-validation/package.json packages/shared-validation/
COPY packages/eslint-config/package.json packages/eslint-config/
COPY packages/tsconfig packages/tsconfig/

RUN pnpm install --frozen-lockfile --filter @luxaria/backend... \
  && chown -R node:node /app

COPY --chown=node:node packages packages
COPY --chown=node:node apps/backend apps/backend

USER node

RUN pnpm --filter @luxaria/shared-types build

WORKDIR /app

EXPOSE 9000

HEALTHCHECK --interval=15s --timeout=5s --start-period=60s --retries=5 \
  CMD curl -fsS http://127.0.0.1:9000/api/v1/health >/dev/null || exit 1

# Rebuild workspace packages on boot (src may be bind-mounted), then Nest watch.
CMD ["sh", "-c", "pnpm --filter @luxaria/shared-types build && pnpm --filter @luxaria/backend exec nest start --watch"]
