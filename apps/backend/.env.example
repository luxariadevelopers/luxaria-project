NODE_ENV=development
PORT=9000
APP_NAME=Luxaria Developers ERP API
APP_VERSION=0.1.0
MONGODB_URI=mongodb://127.0.0.1:9017/luxaria-erp

# Comma-separated browser origins (required in production; never use *)
CORS_ORIGINS=http://localhost:9001,http://localhost:9002
SWAGGER_ENABLED=true
LOG_LEVEL=debug

# Secrets — generate unique values (≥32 chars). Required in production.
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FIELD_ENCRYPTION_KEY=replace-with-long-random-field-encryption-key

AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=.example.com

# R-003 project isolation: enforce (default) | observe (staging temporary only)
PROJECT_ACCESS_ENFORCEMENT=enforce

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_S3_PREFIX=luxaria-developers/
AWS_S3_MAX_UPLOAD_BYTES=26214400
AWS_S3_PRESIGN_EXPIRES_SECONDS=900

REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=9018
REDIS_PASSWORD=

# AWS SES SMTP (leave unset for stub/dev logging only)
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Luxaria Developers <noreply@luxariadevelopers.com>

# Observability / operational alerts (Phase 140)
ERROR_TRACKING_ENABLED=false
# ERROR_TRACKING_DSN=https://errors.example.com/ingest/project-id
# OPS_ALERT_WEBHOOK_URL=https://hooks.example.com/ops-alerts
ALERT_DELIVERY_FAILURE_THRESHOLD_24H=10
ALERT_DATABASE_DOWN_ENABLED=true
ALERT_REDIS_DOWN_ENABLED=true
