NODE_ENV=test
PORT=9003
APP_NAME=Luxaria Developers ERP API
APP_VERSION=0.1.0
MONGODB_URI=mongodb://127.0.0.1:9017/luxaria-erp-test
CORS_ORIGINS=http://localhost:9001
SWAGGER_ENABLED=false
LOG_LEVEL=error
JWT_ACCESS_SECRET=luxaria-test-access-secret
JWT_REFRESH_SECRET=luxaria-test-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=30

FIELD_ENCRYPTION_KEY=luxaria-dev-field-encryption-key-change-me-32b

STOCK_REORDER_JOBS_ENABLED=false
REDIS_ENABLED=false

# Daily Progress Reports — missing DPR alerts
DPR_MISSING_JOBS_ENABLED=true
DPR_MISSING_CRON=0 20 * * *
