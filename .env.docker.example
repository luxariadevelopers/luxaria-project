# Copy to .env.docker for docker compose:
#   cp .env.docker.example .env.docker
#
# Used by backend/web containers. Host-only pnpm still uses apps/backend/.env.

NODE_ENV=development
PORT=9000
APP_NAME=Luxaria Developers ERP API
APP_VERSION=0.1.0

# Live MongoDB Atlas only (no local Mongo container in this stack)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/luxaria-erp?retryWrites=true&w=majority
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

CORS_ORIGINS=http://localhost:9001,http://127.0.0.1:9001
SWAGGER_ENABLED=true
LOG_LEVEL=debug

# Replace with unique ≥32-char secrets before any shared/staging use
JWT_ACCESS_SECRET=docker-dev-access-secret-change-me-32chars
JWT_REFRESH_SECRET=docker-dev-refresh-secret-change-me-32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FIELD_ENCRYPTION_KEY=docker-dev-field-encryption-key-32chars!!

AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=30
PROJECT_ACCESS_ENFORCEMENT=enforce
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

AWS_REGION=ap-south-1
# Prefer `aws login --profile luxaria` + AWS_PROFILE for local/dev (Luxaria account).
AWS_PROFILE=luxaria
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=luxaria-app-380267956124
AWS_S3_PREFIX=luxaria-developers/
AWS_S3_MAX_UPLOAD_BYTES=26214400
AWS_S3_PRESIGN_EXPIRES_SECONDS=900

# AWS SES SMTP (leave SMTP_USER/SMTP_PASS empty for stub mode)
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Luxaria Developers <noreply@luxariadevelopers.com>

# Vite (dev container proxies API to backend service)
VITE_API_BASE_URL=/api/v1
VITE_PROXY_TARGET=http://backend:9000

# Mongo Express (profile: tools) — disable basic auth only for local Docker
ME_CONFIG_BASICAUTH=false
